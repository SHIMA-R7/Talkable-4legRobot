# .env.example
# ==============
# このファイルを .env にコピーして実際の値を記入する。
# .env は .gitignore に追加し、絶対にリポジトリにコミットしないこと。

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Tailscale ---
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxx

# --- ネットワーク上書き (オプション) ---
# ROBOT_NETWORK_SERVER_HOST=100.x.x.x
# ROBOT_NETWORK_SERVER_PORT=8000

# --- ログレベル上書き (オプション) ---
# ROBOT_SYSTEM_LOG_LEVEL=DEBUG
